{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    }
  },
  "WhisperSettings": {
    // Name of Whisper model/file (e.g., "ggml-medium.bin").
    // Ensure this file exists in the 'Assets' directory.
    "ModelName": "ggml-base",

    // ==========================================
    // CORE SETTINGS (Hardware & Basics)
    // ==========================================

    // Global hardware backend to use. 
    // Options: "Auto", "Cuda", "Vulkan", "Cpu".
    "HardwareBackend": "Auto",

    // Index of the GPU to use (0 for the primary graphics card).
    "GpuDeviceIndex": 0,

    // Number of threads to use when falling back to CPU inference.
    "Threads": null,

    // Target language. Use "auto" for detection, or ISO codes ("ru", "en").
    // Auto is slower.
    "Language": "en",

    // Automatically translate the transcribed text to English.
    "Translate": false,

    // ==========================================
    // PROCESSING FLAGS
    // ==========================================

    // Do not use past transcription context (speeds up processing slightly).
    "NoContext": false,

    // Force single segment output rather than splitting across multiple segments.
    "SingleSegment": true,

    // Include timestamps in the generated output.
    "PrintTimestamps": true,

    // Enable token-level timestamps for extreme precision.
    "UseTokenTimestamps": false,

    // Split text on words rather than tokens (requires UseTokenTimestamps = true).
    "SplitOnWord": false,

    // Compute the probability for each token.
    "ComputeProbabilities": false,

    // Suppress outputting blank/empty audio segments.
    "SuppressBlank": true,

    // ==========================================
    // CONTEXT & PROMPTS
    // ==========================================

    // Context prompt to guide the model (e.g., a dictionary of terms/names).
    "Prompt": null,

    // Carry the initial prompt forward into subsequent segments of long audio.
    "CarryInitialPrompt": false,

    // Regex pattern to suppress specific outputs (leave empty to disable).
    "SuppressRegex": "",

    // ==========================================
    // ADVANCED THRESHOLDS
    // ==========================================

    // Start transcription from this point in time. Format: "00:00:00".
    "Offset": null,

    // Maximum duration of audio to process. Format: "00:05:00".
    "Duration": null,

    // 0.0 = greedy/accurate, > 0.0 = creative/hallucination risk
    "Temperature": null,

    // Increment step for temperature fallback if decoding fails. Format: 0.0.
    "TemperatureInc": null,

    // Fallback to higher temp if entropy is above this. Format: 0.0.
    "EntropyThreshold": null,

    // Fallback if average log probability is below this. Format: -0.0.
    "LogProbThreshold": null,

    // Skip decoding if the no-speech probability is high. Format: 0.0.
    "NoSpeechThreshold": null,

    // ==========================================
    // OPENVINO SPECIFIC (Intel Hardware Only)
    // ==========================================

    "OpenVinoEncoderPath": null,

    "OpenVinoDevice": null,

    "OpenVinoCacheDir": null
  },
  "RecordingDeviceSettings": {
    "DeviceIndex": 0,

    // Minimum volume level (normalized from 0.0 to 1.0) required to trigger the start of recording.
    // Automatically trims absolute silence/background static before you actually start speaking.
    // Recommended values: 0.01 - 0.05 depending on microphone sensitivity.
    "SilenceThreshold": 0.01,

    // Indicates whether microphone amplitude will be output in the console.
    // Useful for debugging purposes to set correct 'SilenceThreshold'.
    "OutputMicAmplitudeDebugInfo": false,

    // Determines how frequently (in milliseconds) the audio hardware sends data chunks to the application.
    // Lower value = less latency/faster response, but slightly higher CPU load. 
    // NAudio default is 100ms. 50ms is optimal for real-time AI processing.
    "BufferMs": 50,

    // Number of internal buffers allocated for recording. 
    // Increase this (e.g., to 4 or 5) if you experience audio dropouts or stuttering on slower CPUs.
    // Default is 3.
    "NumberOfBuffers": 3
  },
  "TextInsertionSettings": {
    // Auto inserts text under caret.
    // If set to false it still is saved to clipboard and you can Ctrl-V manually.
    "UseAutoInsert": true
  },
  "PushToTalkSettings": {
    "PlaySound": true,
    "Volume": 0.1,
    "Key": "`",
    "Modifier": ""
  }
}